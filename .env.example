# Example environment for the flash-sale platform.
# Copy to .env and fill in real values. NEVER commit the real .env (it is
# git-ignored). Every secret comes from here — nothing is hardcoded (NFR-8).

# ─────────────────────────────────────────────────────────────────────────────
# Local development
#
#   apps (web/api/worker) run on the HOST via pnpm;
#   `docker compose up` brings up Postgres (+pgvector) and Redis locally.
#
# The DATABASE_URL / REDIS_URL below point at those local containers.
# ─────────────────────────────────────────────────────────────────────────────

# App ports (apps read these; web/api are published, worker is health-only).
WEB_PORT=3000
API_PORT=3001
WORKER_PORT=3002

# Local Postgres container — these are consumed by docker-compose.yml AND must
# match the credentials in DATABASE_URL below.
POSTGRES_USER=flash
POSTGRES_PASSWORD=flash
POSTGRES_DB=flash_sale

# Connection strings (local containers on localhost).
# Prisma migrations need the DIRECT connection (port 5432) — see packages/db/CLAUDE.md.
DATABASE_URL=postgresql://flash:flash@localhost:5432/flash_sale?schema=public
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# Production (docker-compose.prod.yml)
#
#   apps run in docker-compose on a single host; databases are EXTERNAL managed
#   services (technical-design §8). Override the two URLs below — leave the rest.
#
#   Supabase: use the DIRECT connection (port 5432) for migrations.
#   Upstash:  use the TLS scheme (rediss://).
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:<password>@<project>.supabase.com:5432/postgres
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
