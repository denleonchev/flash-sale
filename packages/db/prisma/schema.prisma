// Prisma schema for the flash-sale platform.
// Source of truth for the data model is docs/technical-design.md §5.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  // Prisma 7: the connection URL lives in prisma.config.ts, not here.
  // (NFR-8: value comes from env, never hardcoded.)
  provider = "postgresql"
}

// Mirrors OrderStatus in packages/shared and orders.status in §5.
// api writes in_progress before enqueue; the worker transitions it to exactly one
// terminal status (confirmed | sold_out | failed). See §4 purchase flow.
enum OrderStatus {
  in_progress
  confirmed
  sold_out
  failed
}

/// A sale / drop (the "event"). State (upcoming/live/ended) is derived from time
/// + stock, never stored (FR-2). Authoritative stock = stockTotal minus confirmed
/// orders (§5).
model Sale {
  id          String   @id @default(uuid())
  title       String
  description String?
  stockTotal  Int      @map("stock_total")
  priceCents  Int      @map("price_cents") // FR-12: sale price; Stripe charges this exact amount
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  createdAt   DateTime @default(now()) @map("created_at")
  // FR-26: set by the embed-sale worker job (S-6.2); null until first job completes.
  embedding   Unsupported("vector(384)")?

  orders     Order[]
  fraudFlags FraudFlag[]

  @@map("sales")
}

/// FR-6 / FR-23: thin mirror of Auth0 identity. Populated via upsert on first
/// purchase; Auth0 remains the source of truth for authentication.
model User {
  auth0Sub  String   @id @map("auth0_sub")
  email     String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

/// A buyer's order for a sale.
///
/// Concurrency note (FR-14 / NFR-2): `idempotency_key` is UNIQUE — the DB-level
/// dedup point. The api INSERTs `in_progress` before enqueue; a double-click loses
/// the INSERT race on P2002 and releases its reservation. The worker UPDATEs the
/// row to a terminal status (guarded by `WHERE status = in_progress`) so a
/// re-delivered job acts at most once without a second INSERT. The guarded stock
/// write (S-4.1) runs inside the same $transaction in §4 step 8.
model Order {
  id             String      @id @default(uuid())
  saleId         String      @map("sale_id")
  buyerId        String      @map("buyer_id") // plain field for now; FK to users arrives with auth
  idempotencyKey String      @unique @map("idempotency_key")
  status         OrderStatus
  createdAt      DateTime    @default(now()) @map("created_at")
  // Set when the buyer acknowledges the result notification (FR-19). Snapshot is
  // suppressed on subsequent subscriptions once acknowledged.
  acknowledgedAt DateTime?   @map("acknowledged_at")
  // FR-12 [Ext]: Stripe PaymentIntent ID; null when using the fake payment provider.
  paymentRef     String?     @map("payment_ref")

  sale      Sale       @relation(fields: [saleId], references: [id])
  fraudFlag FraudFlag?

  @@map("orders")
}

enum RiskLevel {
  low
  medium
  high
}

enum FraudFlagStatus {
  open
  reviewed
}

/// FR-27: результат fraud screening. embedding — вектор текстового паттерна,
/// используется как база прецедентов для RAG в следующих проверках.
model FraudFlag {
  id        String    @id @default(uuid())
  orderId   String    @unique @map("order_id")
  buyerId   String    @map("buyer_id")
  saleId    String    @map("sale_id")
  risk       RiskLevel
  reason     String
  pattern    String
  embedding  Unsupported("vector(384)")?
  status     FraudFlagStatus @default(open)
  createdAt  DateTime        @default(now()) @map("created_at")
  reviewedAt DateTime?       @map("reviewed_at")

  order Order @relation(fields: [orderId], references: [id])
  sale  Sale  @relation(fields: [saleId], references: [id])

  @@map("fraud_flags")
}
