{
  "name": "@flash-sale/db",
  "version": "0.0.0",
  "private": true,
  "main": "generated/client/index.js",
  "types": "generated/client/index.d.ts",
  "exports": {
    ".": {
      "types": "./generated/client/index.d.ts",
      "default": "./generated/client/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "test:integration:stripe-concurrency": "tsx integration/stripe-concurrency/main.ts",
    "postinstall": "prisma generate && tsc"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "bullmq": "^5.78.1",
    "dotenv": "^16.4.7",
    "prisma": "^7.8.0",
    "stripe": "^22.2.3",
    "tsx": "^4.22.4"
  }
}
