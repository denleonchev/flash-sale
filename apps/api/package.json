{
  "name": "@flash-sale/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "start": "node --env-file-if-exists=../../.env dist/main.js",
    "dev": "tsc-watch --noClear --onSuccess \"node --env-file-if-exists=../../.env dist/main.js\"",
    "dev:debug": "tsc-watch --noClear --onSuccess \"node --env-file-if-exists=../../.env --inspect-brk=9229 dist/main.js\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@flash-sale/db": "workspace:^",
    "@flash-sale/shared": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/websockets": "^11.1.26",
    "@socket.io/redis-adapter": "^8.3.0",
    "@xenova/transformers": "^2.17.2",
    "bullmq": "^5.78.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsc-watch": "^6.2.1"
  }
}